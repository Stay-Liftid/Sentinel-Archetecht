/**
 * SentinelRouting - Multi-Modal Communication Routing
 */
class SentinelRouting {
  constructor(p2pNode) {
    this.p2pNode = p2pNode;
    this.routes = new Map();
    this.messageQueue = new Map();
    this.routingTable = new Map();
  }
  
  /**
   * Route text message
   */
  async routeTextMessage(sender, recipient, message) {
    const encryptedMessage = await this.encryptMessage(message);
    
    const route = {
      type: 'text',
      sender,
      recipient,
      timestamp: Date.now(),
      encrypted: encryptedMessage,
      priority: 'normal'
    };
    
    return this.sendRoute(route);
  }
  
  /**
   * Route voice call
   */
  async routeVoiceCall(sender, recipient, sdpOffer) {
    const encryptedSDP = await this.encryptMessage(sdpOffer);
    
    const route = {
      type: 'voice',
      sender,
      recipient,
      timestamp: Date.now(),
      encrypted: encryptedSDP,
      priority: 'high'
    };
    
    return this.sendRoute(route);
  }
  
  /**
   * Route video call
   */
  async routeVideoCall(sender, recipient, sdpOffer) {
    const encryptedSDP = await this.encryptMessage(sdpOffer);
    
    const route = {
      type: 'video',
      sender,
      recipient,
      timestamp: Date.now(),
      encrypted: encryptedSDP,
      priority: 'high'
    };
    
    return this.sendRoute(route);
  }
  
  /**
   * Send route through P2P network
   */
  async sendRoute(route) {
    try {
      // Check if recipient is directly connected
      if (this.p2pNode.connections.has(route.recipient)) {
        const stream = await this.p2pNode.libp2p.dialProtocol(
          route.recipient,
          `/sentinel/${route.type}/1.0.0`
        );
        
        await stream.write(JSON.stringify(route));
        return { success: true, route: route.type };
      } else {
        // Store in DHT for offline delivery
        await this.storeOfflineMessage(route);
        return { success: true, route: 'offline' };
      }
    } catch (error) {
      console.error('Route failed:', error);
      return { success: false, error: error.message };
    }
  }
  
  /**
   * Store offline message in DHT
   */
  async storeOfflineMessage(route) {
    const messageKey = `/sentinel/offline/${route.recipient}`;
    await this.p2pNode.libp2p.dht.put(messageKey, JSON.stringify(route));
  }
  
  /**
   * Retrieve offline messages
   */
  async retrieveOfflineMessages(nodeId) {
    const messageKey = `/sentinel/offline/${nodeId}`;
    const messages = await this.p2pNode.libp2p.dht.get(messageKey);
    return messages ? JSON.parse(messages) : [];
  }
}


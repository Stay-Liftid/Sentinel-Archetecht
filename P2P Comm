const crypto = require('crypto');

/**
 * SentinelEncryption - E2E Reverse Scramble Encryption Implementation
 */
class SentinelEncryption {
  constructor() {
    this.algorithm = 'aes-256-gcm';
    this.keyLength = 32; // 256 bits
    this.ivLength = 16; // 128 bits
    this.saltLength = 32;
    this.scrambleRounds = 5;
  }
  
  /**
   * Generate key pair for E2E encryption
   */
  async generateKeyPair() {
    return crypto.generateKeyPairSync('x25519');
  }
  
  /**
   * Derive shared secret using ECDH
   */
  async deriveSharedSecret(privateKey, publicKey) {
    const sharedSecret = crypto.diffieHellman({
      publicKey: Buffer.from(publicKey, 'hex'),
      privateKey: Buffer.from(privateKey, 'hex')
    });
    
    return sharedSecret.computeSecret(publicKey);
  }
  
  /**
   * Reverse scramble encryption
   * This is the core Sentinel encryption algorithm
   */
  async reverseScrambleEncrypt(data, key) {
    // Generate salt and IV
    const salt = crypto.randomBytes(this.saltLength);
    const iv = crypto.randomBytes(this.ivLength);
    
    // Derive encryption key
    const derivedKey = crypto.pbkdf2Sync(
      key,
      salt,
      100000,
      this.keyLength,
      'sha256'
    );
    
    // Reverse scramble the data
    let scrambledData = Buffer.from(data);
    for (let i = 0; i < this.scrambleRounds; i++) {
      scrambledData = this.reverseScramble(scrambledData, i);
    }
    
    // Encrypt scrambled data
    const cipher = crypto.createCipheriv(this.algorithm, derivedKey, iv);
    let encrypted = cipher.update(scrambledData);
    encrypted = Buffer.concat([encrypted, cipher.final()]);
    
    // Get auth tag
    const authTag = cipher.getAuthTag();
    
    // Combine all components
    const result = Buffer.concat([salt, iv, authTag, encrypted]);
    
    return result.toString('base64');
  }
  
  /**
   * Reverse scramble decryption
   */
  async reverseScrambleDecrypt(encryptedData, key) {
    // Parse encrypted data
    const data = Buffer.from(encryptedData, 'base64');
    const salt = data.slice(0, this.saltLength);
    const iv = data.slice(this.saltLength, this.saltLength + this.ivLength);
    const authTag = data.slice(this.saltLength + this.ivLength, this.saltLength + this.ivLength + 16);
    const encrypted = data.slice(this.saltLength + this.ivLength + 16);
    
    // Derive decryption key
    const derivedKey = crypto.pbkdf2Sync(
      key,
      salt,
      100000,
      this.keyLength,
      'sha256'
    );
    
    // Decrypt data
    const decipher = crypto.createDecipheriv(this.algorithm, derivedKey, iv);
    decipher.setAuthTag(authTag);
    let decrypted = decipher.update(encrypted);
    decrypted = Buffer.concat([decrypted, decipher.final()]);
    
    // Reverse unscramble the data
    for (let i = this.scrambleRounds - 1; i >= 0; i--) {
      decrypted = this.reverseUnscramble(decrypted, i);
    }
    
    return decrypted.toString();
  }
  
  /**
   * Reverse scramble algorithm
   */
  reverseScramble(data, round) {
    const result = Buffer.alloc(data.length);
    const seed = round * 0x5DEECE66DL + 0xBL;
    
    for (let i = 0; i < data.length; i++) {
      const offset = (seed + i) % data.length;
      result[i] = data[offset];
    }
    
    return result;
  }
  
  /**
   * Reverse unscramble algorithm
   */
  reverseUnscramble(data, round) {
    const result = Buffer.alloc(data.length);
    const seed = round * 0x5DEECE66DL + 0xBL;
    
    for (let i = 0; i < data.length; i++) {
      const offset = (seed + i) % data.length;
      result[offset] = data[i];
    }
    
    return result;
  }
}


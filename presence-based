// Bluetooth device discovery handler
static int bluetooth_device_discovered(const struct hci_dev *hdev,
                                       const struct hci_conn *conn,
                                       const struct hci_ev_le_meta *meta,
                                       const void *data) {
    
    const struct sentinel_beacon_payload *beacon = data;
    
    // Verify beacon protocol
    if (beacon->protocol_version != SENTINEL_BEACON_VERSION) {
        return 0;  // Not our beacon
    }
    
    // Verify beacon signature
    if (!verify_beacon_signature(beacon)) {
        printk(KERN_WARNING "Invalid beacon signature\n");
        return 0;
    }
    
    // Extract viewer ID hash
    memcpy(auth_context.viewer_id_hash, beacon->viewer_id_hash, 16);
    
    // Calculate distance from RSSI
    int rssi = conn->rssi;
    float distance = calculate_distance(rssi);
    
    printk(KERN_DEBUG "Beacon detected: distance=%.2fm\n", distance);
    
    // Check proximity threshold
    if (distance < PROXIMITY_THRESHOLD_NEAR) {
        // Update authentication state
        handle_auth_state_transition(AUTH_PROXIMITY_DETECTED);
    }
    
    return 0;
}

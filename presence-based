### 3.2 Authentication State Machine

#### 3.2.1 State Transition Implementation

```c
// State transition handler
static int handle_auth_state_transition(enum sentinel_auth_state new_state) {
    int ret = 0;
    
    printk(KERN_DEBUG "State transition: %d -> %d\n", 
           auth_context.state, new_state);
    
    // Validate state transition
    if (!is_valid_transition(auth_context.state, new_state)) {
        printk(KERN_WARNING "Invalid state transition attempted\n");
        return -EINVAL;
    }
    
    // Perform state-specific actions
    switch (new_state) {
        case AUTH_PROXIMITY_DETECTED:
            ret = handle_proximity_detected();
            break;
            
        case AUTH_COLOCATION_VERIFIED:
            ret = handle_colocation_verified();
            break;
            
        case AUTH_HUMAN_CONFIRMED:
            ret = handle_human_confirmed();
            break;
            
        case AUTH_FULLY_AUTHENTICATED:
            ret = handle_fully_authenticated();
            break;
            
        default:
            printk(KERN_WARNING "Unknown state: %d\n", new_state);
            ret = -EINVAL;
    }
    
    // Update state if transition successful
    if (ret == 0) {
        auth_context.state = new_state;
        do_gettimeofday(&auth_context.last_update);
        
        // Notify user-space of state change
        notify_state_change(new_state);
    }
    
    return ret;
}

// Validate state transition
static bool is_valid_transition(enum sentinel_auth_state current, 
                                enum sentinel_auth_state new_state) {
    // Define valid state transitions
    static const bool transition_matrix[5][5] = {
        // From\To:  UNAUTH  PROX   COLOC  HUMAN  FULL
        /* UNAUTH */ {false, true,  false, false, false},
        /* PROX  */  {true,  true,  true,  false, false},
        /* COLOC */  {true,  true,  true,  true,  false},
        /* HUMAN */  {true,  true,  true,  true,  true},
        /* FULL  */  {true,  true,  true,  true,  true}
    };
    
    return transition_matrix[current][new_state];
}
```


### 2.2 Proximity Detection Algorithm

#### 2.2.1 RSSI-Based Distance Calculation

```python
def calculate_distance_from_rssi(rssi, tx_power=-20):
    """Calculate approximate distance from RSSI value."""
    
    if rssi == 0:
        return -1.0  # Unknown distance
    
    # Path loss model
    ratio = rssi * 1.0 / tx_power
    if ratio < 1.0:
        return pow(ratio, 10)
    else:
        distance = (0.89976) * pow(ratio, 7.7095) + 0.111
    
    return distance
```

#### 2.2.2 Kalman Filter Implementation

```python
class KalmanFilter:
    """Kalman filter for RSSI signal smoothing."""
    
    def __init__(self, process_variance=1e-4, measurement_variance=1e-1):
        self.process_variance = process_variance
        self.measurement_variance = measurement_variance
        self.estimate = 0.0
        self.estimate_error = 1.0
    
    def update(self, measurement):
        """Update filter with new measurement."""
        
        # Prediction
        self.estimate_error = self.estimate_error + self.process_variance
        
        # Update
        kalman_gain = self.estimate_error / (self.estimate_error + self.measurement_variance)
        self.estimate = self.estimate + kalman_gain * (measurement - self.estimate)
        self.estimate_error = (1 - kalman_gain) * self.estimate_error
        
        return self.estimate
```


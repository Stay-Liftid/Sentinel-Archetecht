class SentinelMonitoring:
    """Monitoring system for Sentinel authentication."""
    
    def __init__(self):
        self.metrics = {
            'authentication_success_rate': 0.0,
            'average_authentication_time': 0.0,
            'false_positive_rate': 0.0,
            'false_negative_rate': 0.0,
            'system_uptime': 0.0
        }
    
    def collect_metrics(self):
        """Collect current system metrics."""
        
        # Collect authentication metrics
        auth_events = self.get_authentication_events()
        
        total_events = len(auth_events)
        successful_events = sum(1 for e in auth_events if e['success'])
        
        if total_events > 0:
            self.metrics['authentication_success_rate'] = \
                successful_events / total_events
            
            self.metrics['average_authentication_time'] = \
                sum(e['duration'] for e in auth_events) / total_events
        
        # Collect system metrics
        self.metrics['system_uptime'] = self.get_system_uptime()
        
        return self.metrics
    
    def generate_alerts(self):
        """Generate alerts for metric thresholds."""
        
        alerts = []
        
        # Check authentication success rate
        if self.metrics['authentication_success_rate'] < 0.99:
            alerts.append({
                'severity': 'WARNING',
                'message': 'Authentication success rate below 99%'
            })
        
        # Check average authentication time
        if self.metrics['average_authentication_time'] > 0.5:
            alerts.append({
                'severity': 'WARNING',
                'message': 'Average authentication time exceeds 500ms'
            })
        
        return alerts

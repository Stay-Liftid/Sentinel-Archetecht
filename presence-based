## 5. Security Implementation Details

### 5.1 Cryptographic Security

#### 5.1.1 Beacon Payload Encryption

```python
from cryptography.hazmat.primitives.ciphers import Cipher, algorithms, modes
from cryptography.hazmat.backends import default_backend

def encrypt_beacon_payload(payload, key):
    """Encrypt beacon payload using AES-256-GCM."""
    
    # Generate random IV
    iv = os.urandom(12)
    
    # Create cipher
    cipher = Cipher(
        algorithms.AES(key),
        modes.GCM(iv),
        backend=default_backend()
    )
    encryptor = cipher.encryptor()
    
    # Encrypt payload
    ciphertext = encryptor.update(payload) + encryptor.finalize()
    
    # Get authentication tag
    tag = encryptor.tag
    
    return iv + ciphertext + tag

def decrypt_beacon_payload(encrypted_data, key):
    """Decrypt beacon payload using AES-256-GCM."""
    
    # Extract components
    iv = encrypted_data[:12]
    tag = encrypted_data[-16:]
    ciphertext = encrypted_data[12:-16]
    
    # Create cipher
    cipher = Cipher(
        algorithms.AES(key),
        modes.GCM(iv, tag),
        backend=default_backend()
    )
    decryptor = cipher.decryptor()
    
    # Decrypt payload
    payload = decryptor.update(ciphertext) + decryptor.finalize()
    
    return payload
```

### 5.2 Anti-Spoofing Measures

#### 5.2.1 Liveness Detection

```python
class LivenessDetector:
    """Liveness detection for biometric verification."""
    
    def __init__(self):
        self.challenge_cache = {}
    
    def generate_challenge(self):
        """Generate random liveness challenge."""
        challenge = {
            'timestamp': time.time(),
            'random_value': os.urandom(32),
            'action': random.choice(['blink', 'smile', 'turn_head']),
            'expiration': time.time() + 30  # 30 seconds
        }
        
        challenge_id = hashlib.sha256(json.dumps(challenge).encode()).hexdigest()
        self.challenge_cache[challenge_id] = challenge
        
        return challenge_id, challenge
    
    def verify_response(self, challenge_id, response):
        """Verify liveness challenge response."""
        
        if challenge_id not in self.challenge_cache:
            return False, "Invalid challenge ID"
        
        challenge = self.challenge_cache[challenge_id]
        
        # Check expiration
        if time.time() > challenge['expiration']:
            del self.challenge_cache[challenge_id]
            return False, "Challenge expired"
        
        # Verify response matches expected action
        if response.get('action') != challenge['action']:
            return False, "Incorrect action response"
        
        # Verify timestamp freshness
        response_time = response.get('timestamp')
        if abs(time.time() - response_time) > 5.0:  # 5 seconds tolerance
            return False, "Response too old"
        
        # Clean up challenge
        del self.challenge_cache[challenge_id]
        
        return True, "Liveness verified"
```


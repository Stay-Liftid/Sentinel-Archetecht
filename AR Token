## 📱 Mobile App Integration

### iOS Implementation

```swift
// AR Token Capture iOS Implementation
import ARKit
import CoreLocation

class ARTokenCaptureViewController: UIViewController, ARSCNViewDelegate, CLLocationManagerDelegate {
    
    @IBOutlet var arView: ARSCNView!
    @IBOutlet var compassView: UICompassView!
    @IBOutlet var tokenCountLabel: UILabel!
    
    var locationManager = CLLocationManager()
    var currentLocation: CLLocation?
    var nearbyTokens: [ARToken] = []
    var selectedToken: ARToken?
    
    override func viewDidLoad() {
        super.viewDidLoad()
        
        // Setup AR
        arView.delegate = self
        let configuration = ARWorldTrackingConfiguration()
        configuration.planeDetection = .horizontal
        arView.session.run(configuration)
        
        // Setup Location
        locationManager.delegate = self
        locationManager.desiredAccuracy = kCLLocationAccuracyBest
        locationManager.requestWhenInUseAuthorization()
        locationManager.startUpdatingLocation()
        
        // Start token discovery
        startTokenDiscovery()
    }
    
    func startTokenDiscovery() {
        guard let location = currentLocation else { return }
        
        TokenDiscovery().findNearbyTokens(
            userLocation: location.coordinate,
            radius: 100
        ) { tokens in
            self.nearbyTokens = tokens
            self.updateCompass()
            self.updateARView()
        }
    }
    
    func updateCompass() {
        compassView.updateTokens(nearbyTokens)
    }
    
    func updateARView() {
        // Add token 3D models to AR scene
        for token in nearbyTokens {
            let tokenNode = createTokenNode(for: token)
            arView.scene.rootNode.addChildNode(tokenNode)
        }
    }
    
    func createTokenNode(for token: ARToken) -> SCNNode {
        let geometry = SCNBox(width: 0.1, height: 0.1, length: 0.1, chamferRadius: 0.02)
        let material = SCNMaterial()
        material.diffuse.contents = token.color
        geometry.materials = [material]
        
        let node = SCNNode(geometry: geometry)
        node.position = token.position
        
        // Add animation
        let spin = SCNAction.rotateBy(x: 0, y: CGFloat.pi * 2, z: 0, duration: 10)
        let repeatSpin = SCNAction.repeatForever(spin)
        node.runAction(repeatSpin)
        
        return node
    }
    
    override func touchesBegan(_ touches: Set<UITouch>, with event: UIEvent?) {
        guard let touch = touches.first else { return }
        let location = touch.location(in: arView)
        
        let hitResults = arView.hitTest(location, options: [:])
        
        if let result = hitResults.first,
           let tokenNode = result.node as? TokenNode {
            captureToken(tokenNode.token)
        }
    }
    
    func captureToken(_ token: ARToken) {
        TokenCapture().captureToken(
            userId: currentUser.id,
            tokenId: token.id
        ) { result in
            if result.success {
                // Show capture animation
                showCaptureAnimation(token: token, reward: result.rewards)
                
                // Update token count
                tokenCountLabel.text = "\(currentUser.tokenBalance) TRV"
                
                // Check for nearby users
                if result.nearbyUsers > 0 {
                    showNearbyUsersAlert(count: result.nearbyUsers)
                }
            }
        }
    }
}

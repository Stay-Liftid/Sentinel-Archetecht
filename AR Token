### Capture Mechanics

#### **1. Token Discovery**
```javascript
// Token Discovery Algorithm
class TokenDiscovery {
  /**
   * Find nearby tokens
   */
  async findNearbyTokens(userLocation, radius = 100) {
    // Get user's GPS location
    const { latitude, longitude } = userLocation;
    
    // Query token database for nearby tokens
    const nearbyTokens = await this.tokenDatabase.query({
      location: {
        $near: {
          $geometry: {
            type: "Point",
            coordinates: [longitude, latitude]
          },
          $maxDistance: radius // meters
        }
      },
      status: 'ACTIVE',
      expiry: { $gt: Date.now() }
    });
    
    // Sort by distance and rarity
    return nearbyTokens
      .sort((a, b) => {
        const distanceA = this.calculateDistance(userLocation, a.location);
        const distanceB = this.calculateDistance(userLocation, b.location);
        return distanceA - distanceB;
      })
      .map(token => ({
        ...token,
        distance: this.calculateDistance(userLocation, token.location),
        direction: this.calculateDirection(userLocation, token.location)
      }));
  }
  
  /**
   * Calculate distance between two points
   */
  calculateDistance(point1, point2) {
    const R = 6371e3; // Earth's radius in meters
    const φ1 = point1.latitude * Math.PI / 180;
    const φ2 = point2.latitude * Math.PI / 180;
    const Δφ = (point2.latitude - point1.latitude) * Math.PI / 180;
    const Δλ = (point2.longitude - point1.longitude) * Math.PI / 180;
    
    const a = Math.sin(Δφ/2) * Math.sin(Δφ/2) +
              Math.cos(φ1) * Math.cos(φ2) *
              Math.sin(Δλ/2) * Math.sin(Δλ/2);
    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
    
    return R * c;
  }
  
  /**
   * Calculate direction to token
   */
  calculateDirection(from, to) {
    const φ1 = from.latitude * Math.PI / 180;
    const φ2 = to.latitude * Math.PI / 180;
    const Δλ = (to.longitude - from.longitude) * Math.PI / 180;
    
    const y = Math.sin(Δλ) * Math.cos(φ2);
    const x = Math.cos(φ1) * Math.sin(φ2) -
              Math.sin(φ1) * Math.cos(φ2) * Math.cos(Δλ);
    
    const θ = Math.atan2(y, x);
    
    return (θ * 180 / Math.PI + 360) % 360; // Convert to degrees
  }
}
```

#### **2. Token Capture**
```javascript
// Token Capture Mechanism
class TokenCapture {
  /**
   * Capture a token
   */
  async captureToken(userId, tokenId) {
    const token = await this.getToken(tokenId);
    const user = await this.getUser(userId);
    
    // Validation checks
    if (!this.validateCapture(user, token)) {
      throw new Error('Capture validation failed');
    }
    
    // Calculate capture rewards
    const rewards = this.calculateCaptureRewards(token, user);
    
    // Execute token capture
    const captureResult = await this.executeCapture(userId, tokenId, rewards);
    
    // Check for nearby users (social discovery)
    const nearbyUsers = await this.findNearbyUsers(user.location, 50);
    
    if (nearbyUsers.length > 0) {
      await this.handleSocialDiscovery(user, nearbyUsers, rewards);
    }
    
    return {
      success: true,
      tokenCaptured: token,
      rewards: rewards,
      nearbyUsers: nearbyUsers.length
    };
  }
  
  /**
   * Validate capture
   */
  validateCapture(user, token) {
    // Check distance
    const distance = this.calculateDistance(user.location, token.location);
    if (distance > 10) { // 10 meter capture radius
      return false;
    }
    
    // Check if already captured
    if (token.capturedBy) {
      return false;
    }
    
    // Check if expired
    if (token.expiry < Date.now()) {
      return false;
    }
    
    // Check capture cooldown
    const lastCapture = user.lastCaptureTime || 0;
    const cooldown = 5 * 60 * 1000; // 5 minutes
    if (Date.now() - lastCapture < cooldown && !user.isPremium) {
      return false;
    }
    
    return true;
  }
  
  /**
   * Calculate capture rewards
   */
  calculateCaptureRewards(token, user) {
    const baseReward = token.value;
    
    // Multipliers
    const rarityMultiplier = this.getRarityMultiplier(token.rarity);
    const userMultiplier = this.getUserMultiplier(user);
    const streakMultiplier = this.getStreakMultiplier(user);
    
    const totalReward = baseReward * rarityMultiplier * userMultiplier * streakMultiplier;
    
    return {
      baseReward,
      rarityMultiplier,
      userMultiplier,
      streakMultiplier,
      totalReward: Math.floor(totalReward)
    };
  }
}
